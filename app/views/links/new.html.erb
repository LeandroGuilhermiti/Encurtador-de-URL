<div class="container">
  <div class="card">
    <h1>🔗 Encurtador de URLs</h1>
    <p class="subtitle">Transforme links longos em algo curto e fácil de partilhar.</p>

    <% if notice %>
      <p class="notice"><%= notice %></p>
    <% end %>

    <%= form_with model: @link, url: links_path, local: true, class: "shortener-form" do |form| %>
      
      <% if @link.errors.any? %>
        <div class="error-box">
          <p>⚠️ Opa! Verifique os erros abaixo:</p>
          <ul>
            <% @link.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="input-group">
        <%= form.label :url_original, "Cole a sua URL longa aqui:" %>
        <%= form.url_field :url_original, 
            required: true, 
            placeholder: "https://www.exemplo.com/sua-url-muito-longa",
            class: "main-input" %>
      </div>

      <div class="actions">
        <%= form.submit "Encurtar URL", class: "btn-submit" %>
      </div>
    <% end %>
  </div>
</div>